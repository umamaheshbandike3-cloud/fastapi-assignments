from fastapi import FastAPI
from pydantic import BaseModel

app = FastAPI()

# Request body model
class Person(BaseModel):
    name: str
    age: int

# POST API
@app.post("/person")
def create_person(person: Person):
    return {
        "message": "Data received successfully",
        "name": person.name,
        "age": person.age
    }
